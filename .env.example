# PostgreSQL
POSTGRES_USER=analytics
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=analytics_dwh
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API
SERVER_API_KEY=your_secret_token_here

# ETL Worker
REDIS_EVENTS_QUEUE=analytics:events:raw
REDIS_BATCH_SIZE=500
